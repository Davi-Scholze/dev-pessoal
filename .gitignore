# em _negocio/contextos/analise-obsidian-kodai.md (whitelist).
.obsidian/

# === Adicionado por KOD.AI em 2026-05-21 (origem: /absorver-midia piloto) ===
# Videos/audios brutos absorvidos via /absorver-midia podem exceder limite GitHub (100MB).
# Mantemos local pra possivel re-processamento, mas NAO no repo.
# Transcript + frames + sintese + manifest SAO commitados.
inbox-*/**/source.mp4
inbox-*/**/source.webm
inbox-*/**/source.mov
inbox-*/**/source.mkv
inbox-*/**/source.avi
inbox-*/**/source.m4v
inbox-*/**/audio.opus
inbox-*/**/audio.m4a
inbox-*/**/audio.mp3
inbox-*/**/audio.wav

# === Adicionado por KOD.AI em 2026-05-25 (origem: feedback Davi fluxo brutos) ===
# Pasta de drop pra brutos que Davi gera (pesquisa Claude Chrome / NotebookLM .md export).
# Davi salva qualquer .md/.pdf/.txt aqui SEM pensar em path/nome.
# IA processa via /capturar + /ativar-notebooklm + /absorver-contexto,
# move pra inbox-davi/<data>-<tema>/ correto. Local-only (nao polui git/raiz).
_brutos-novos/*
!_brutos-novos/README.md
!_brutos-novos/.gitkeep

# === Adicionado por KOD.AI em 2026-05-25 (origem: postmortem-2026-05-25-ui-cycle-violation) ===
# Marker timestamp criado pelo IA após invocar design skills/agents (frontend-designer,
# tailwind-shadcn-scaffold, dev-browser, ver) — destrava o hook enforce-ui-cycle.js
# pra Edit/Write em arquivos visuais (.tsx/.jsx). Expira em 10 minutos.
# Local-only — não polui repo.
.claude/.ui-cycle-acknowledged

# === Adicionado por KOD.AI em 2026-05-26 (origem: /absorver-midia smoke test Kelvin Cleto) ===
# Patterns anteriores (linhas 50-59) usam "inbox-*/**" sem prefixo **/ — só capturam
# inbox-* na raiz. Davi usa _negocio/inbox-davi/<data>-<tema>/, então precisa **/
# prefix pra qualquer profundidade. Aditivo (não remove os anteriores).
**/inbox-*/**/source.mp4
**/inbox-*/**/source.webm
**/inbox-*/**/source.mov
**/inbox-*/**/source.mkv
**/inbox-*/**/source.avi
**/inbox-*/**/source.m4v
**/inbox-*/**/source.webp
**/inbox-*/**/source.jpg
**/inbox-*/**/audio.opus
**/inbox-*/**/audio.m4a
**/inbox-*/**/audio.mp3
**/inbox-*/**/audio.wav

